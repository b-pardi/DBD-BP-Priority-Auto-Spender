__pycache__/
*.pyc
*.pyo
.venv/
*env/

# scraped icon library is large and fully regenerable from src/scraper.py
data/icons/*
!data/icons/.gitkeep
data/icons_index.json
data/labels
data/*.npy
data/bw-bgs/*
!data/bw-bgs/.gitkeep

# regenerable match-template cache (ncc/embed banks, ring presence template, eval renderbanks),
# now kept in its own subfolder so the "cache" it holds is obvious; rebuilt on demand
data/cache/
# legacy locations (pre data/cache split), kept so old checkouts stay clean
data/*.ncc*.npy
data/ring-template.npz

# saved bloodweb screenshots for offline tests can be large
tests/fixtures/*.png
!tests/fixtures/.gitkeep

# pyinstaller exe build output, fully regenerable from dbdbp.spec
build/
dist/

# packaged release zips are uploaded as github release assets, not committed
*.zip

# temp outputs/utils
.tmp/
.claude
