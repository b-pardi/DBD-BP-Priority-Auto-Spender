__pycache__/
*.pyc
*.pyo
.venv/
*env/

# scraped icon library is large and fully regenerable from src/scraper.py
data/icons/*
!data/icons/.gitkeep
data/icons_index.json
data/labels
data/*.npy
data/bw-bgs/*
!data/bw-bgs/.gitkeep

# ncc template cache, rebuilt on demand from the sprites by detect.load_ncc_templates
data/*.ncc*.npy

# node presence template cache, self-built live from the user's own snapped detections
data/ring-template.npz

# saved bloodweb screenshots for offline tests can be large
tests/fixtures/*.png
!tests/fixtures/.gitkeep

# pyinstaller exe build output, fully regenerable from dbdbp.spec
build/
dist/

# temp outputs/utils
.tmp/
.claude
